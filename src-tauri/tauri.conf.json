{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workshop Manager",
  "version": "3.4.0",
  "identifier": "com.workshop-manager.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gestionale Officina",
        "width": 1000,
        "height": 1000
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:estimates.db"]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyQjRCRUE3MzZCM0FFODgKUldTSXJyTTJwNzYwWW1RZ2lqMXpoNW5uRlZOT1JHRnoxK2pmUmplVWJvSlRURFIxSnI5Uzk2S2UK",
      "endpoints": [
        "https://github.com/abdi-El/workshop-manager/releases/latest/download/latest.json"
      ]
    }
  }
}
